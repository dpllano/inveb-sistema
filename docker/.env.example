# ===========================================
# INVEB - Variables de Entorno
# ===========================================
# Copiar este archivo a .env y configurar los valores
#
# cp .env.example .env
# nano .env
# ===========================================

# ===========================================
# BASE DE DATOS
# ===========================================
# Host de la base de datos (usar 'db' para Docker, 'localhost' para local)
DB_HOST=db

# Puerto MySQL
DB_PORT=3306

# Nombre de la base de datos
DB_NAME=envases_ot

# Usuario de la base de datos (NO usar root en produccion)
DB_USER=inveb_user

# Contrasena del usuario
DB_PASSWORD=CAMBIAR_ESTA_CONTRASENA

# Contrasena de root (solo para Docker)
DB_ROOT_PASSWORD=CAMBIAR_CONTRASENA_ROOT

# Puerto externo para MySQL (mapeo de puertos Docker)
DB_EXTERNAL_PORT=3306

# ===========================================
# JWT - AUTENTICACION
# ===========================================
# Clave secreta para firmar tokens (MINIMO 32 caracteres)
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_ESTA_CLAVE_SECRETA_MIN_32_CARACTERES

# Algoritmo de encriptacion
JWT_ALGORITHM=HS256

# Tiempo de expiracion del token en minutos (1440 = 24 horas)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# ENTORNO
# ===========================================
# Valores: development, staging, production
ENVIRONMENT=development

# Habilitar modo debug (true/false)
DEBUG=true

# ===========================================
# FRONTEND
# ===========================================
# URL de la API (usar /api en produccion con nginx)
VITE_API_URL=http://localhost:8000
