# INVEB Backend - Variables de Entorno
# El sistema soporta múltiples nombres de variables para compatibilidad

# ============================================
# OPCIÓN 1: Variables Railway (automáticas)
# Railway inyecta estas variables cuando agregas MySQL
# ============================================
# MYSQL_HOST=containers-xxx.railway.app
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=xxx
# MYSQL_DATABASE=railway

# ============================================
# OPCIÓN 2: Variables Docker/Local
# Usar estas para desarrollo local
# ============================================
LARAVEL_MYSQL_HOST=127.0.0.1
LARAVEL_MYSQL_PORT=3306
LARAVEL_MYSQL_USER=envases
LARAVEL_MYSQL_PASSWORD=secret
LARAVEL_MYSQL_DATABASE=invebchile_envases_ot

# ============================================
# Configuración de Aplicación
# ============================================
APP_NAME=INVEB Envases OT API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ============================================
# JWT Authentication (IMPORTANTE: cambiar en producción)
# ============================================
JWT_SECRET_KEY=genera-una-clave-secreta-muy-larga-y-segura-aqui-minimo-32-caracteres
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# API
# ============================================
API_PREFIX=/api/v1

# ============================================
# Archivos (Railway usa /app/files por defecto)
# ============================================
FILES_DIR=/app/files
